{
  "expo": {
    "name": "Hangul Route",
    "slug": "hangul-route",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#FCF8F1",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hangulroute.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.hangulroute.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FCF8F1"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-status-bar"]
  }
}
